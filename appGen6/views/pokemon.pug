extends layout

block content
  style.
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Arial', sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    h1 {
      text-align: center;
      color: white;
      font-size: 3rem;
      margin-bottom: 40px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
      animation: fadeInDown 1s ease-out;
    }

    .intro {
      text-align: center;
      color: rgba(255,255,255,0.9);
      margin-bottom: 20px;
      font-size: 1.1rem;
      line-height: 1.4;
    }

    .pokemon-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }

    .pokemon-card {
      background: rgba(255, 255, 255, 0.95);
      border-radius: 15px;
      padding: 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      animation: fadeInDown 0.6s ease-out both;
    }

    .pokemon-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    .pokemon-card-header {
      display: flex;
      gap: 15px;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }

    .pokemon-image {
      width: 100px;
      height: 100px;
      object-fit: contain;
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255,255,255,0.5);
    }

    .pokemon-card-title {
      text-align: center;
      flex: 1 1 160px;
    }

    .pokemon-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin-top: 6px;
      color: #555;
      font-size: 0.95rem;
    }

    .pokemon-number {
      background: rgba(0,0,0,0.08);
      padding: 3px 10px;
      border-radius: 12px;
      font-weight: 600;
    }

    .pokemon-category {
      background: rgba(102, 126, 234, 0.15);
      padding: 3px 10px;
      border-radius: 12px;
      font-weight: 600;
    }

    .pokemon-types {
      margin-top: 10px;
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pokemon-type {
      display: inline-block;
      background: linear-gradient(45deg, #ff6b6b, #ffa500);
      color: white;
      padding: 5px 15px;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: bold;
      margin-bottom: 15px;
      text-align: center;
    }

    .pokemon-description {
      color: #666;
      line-height: 1.6;
      text-align: center;
      margin: 15px 0;
    }

    .pokemon-specs {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 10px;
      color: #444;
      font-size: 0.95rem;
    }

    .pokemon-abilities {
      margin-top: 12px;
      font-size: 0.95rem;
      color: #444;
    }

    .pokemon-abilities ul {
      margin-top: 8px;
      padding-left: 1.2rem;
    }

    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-top: 40px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .page-btn {
      display: inline-block;
      padding: 10px 15px;
      background: rgba(255, 255, 255, 0.9);
      color: #333;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      transition: all 0.3s ease;
      border: 2px solid transparent;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .page-btn:hover {
      background: rgba(102, 126, 234, 0.9);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.2);
    }

    .current-page {
      background: linear-gradient(45deg, #667eea, #764ba2);
      color: white;
      border: 2px solid rgba(255,255,255,0.3);
      cursor: default;
    }

    .current-page:hover {
      transform: none;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .prev-btn, .next-btn {
      font-weight: bold;
      background: rgba(102, 126, 234, 0.9);
      color: white;
    }

    .prev-btn:hover, .next-btn:hover {
      background: rgba(76, 102, 196, 0.9);
    }

    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 2rem;
      }
      .pokemon-grid {
        grid-template-columns: 1fr;
      }
    }

  .container
    h1= title
    p.intro Aqui você encontra uma mini enciclopédia com informações detalhadas de cada Pokémon: tipos, habilidades, medidas e curiosidades.
    .pokemon-grid
      each pokemon in pokemons
        .pokemon-card
          .pokemon-card-header
            img.pokemon-image(src=pokemon.image, alt=pokemon.name)
            .pokemon-card-title
              h2.pokemon-name= pokemon.name
              .pokemon-meta
                span.pokemon-number ##{pokemon.number}
                span.pokemon-category= pokemon.category
              .pokemon-types
                each type in pokemon.type
                  span.pokemon-type= type
          p.pokemon-description= pokemon.description
          .pokemon-specs
            div
              strong Altura:
              |  #{pokemon.height}
            div
              strong Peso:
              |  #{pokemon.weight}
          .pokemon-abilities
            strong Habilidades:
            ul
              each ability in pokemon.abilities
                li= ability

    // Controles de Paginação
    .pagination
      if hasPrev
        a.page-btn.prev-btn(href=`?page=${prevPage}`) ← Anterior
      span.page-btn.current-page Página #{currentPage} de #{totalPages}
      if hasNext
        a.page-btn.next-btn(href=`?page=${nextPage}`) Próximo →
