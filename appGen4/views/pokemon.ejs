<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .intro {
            text-align: center;
            color: rgba(255,255,255,0.9);
            margin-bottom: 20px;
            font-size: 1.1rem;
            line-height: 1.4;
        }

        h1 {
            text-align: center;
            color: white;
            font-size: 3rem;
            margin-bottom: 40px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            animation: fadeInDown 1s ease-out;
        }

        .pokemon-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .pokemon-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .pokemon-name {
            font-size: 1.8rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
            text-align: center;
        }

        .pokemon-type {
            display: inline-block;
            background: linear-gradient(45deg, #ff6b6b, #ffa500);
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: bold;
            margin-bottom: 15px;
            text-align: center;
        }

        .pokemon-description {
            color: #666;
            line-height: 1.6;
            text-align: center;
            margin: 15px 0;
        }

        .pokemon-card-header {
            display: flex;
            gap: 15px;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        .pokemon-image {
            width: 100px;
            height: 100px;
            object-fit: contain;
            border-radius: 12px;
            border: 1px solid rgba(0,0,0,0.08);
            background: rgba(255,255,255,0.5);
        }

        .pokemon-card-title {
            text-align: center;
            flex: 1 1 160px;
        }

        .pokemon-meta {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin-top: 6px;
            color: #555;
            font-size: 0.95rem;
        }

        .pokemon-number {
            background: rgba(0,0,0,0.08);
            padding: 3px 10px;
            border-radius: 12px;
            font-weight: 600;
        }

        .pokemon-category {
            background: rgba(102, 126, 234, 0.15);
            padding: 3px 10px;
            border-radius: 12px;
            font-weight: 600;
        }

        .pokemon-types {
            margin-top: 10px;
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .pokemon-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.18);
            animation: fadeInDown 0.6s ease-out both;
        }

        .pokemon-specs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 10px;
            color: #444;
            font-size: 0.95rem;
        }

        .pokemon-abilities {
            margin-top: 12px;
            font-size: 0.95rem;
            color: #444;
        }

        .pokemon-abilities ul {
            margin-top: 8px;
            padding-left: 1.2rem;
        }

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            margin-top: 40px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .page-btn {
            display: inline-block;
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.9);
            color: #333;
            text-decoration: none;
            border-radius: 8px;
            border: 2px solid rgba(102, 126, 234, 0.3);
            transition: all 0.3s ease;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .page-btn:hover {
            background: rgba(102, 126, 234, 0.8);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

        .current-page {
            background: rgba(102, 126, 234, 0.9);
            color: white;
            border-color: rgba(102, 126, 234, 0.9);
            cursor: default;
        }

        .page-numbers {
            display: flex;
            gap: 8px;
        }

        .prev-btn, .next-btn {
            font-weight: bold;
            background: rgba(255, 255, 255, 0.95);
            border-color: rgba(52, 152, 219, 0.4);
        }

        .prev-btn:hover, .next-btn:hover {
            background: rgba(52, 152, 219, 0.8);
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 2rem;
            }
            .pokemon-grid {
                grid-template-columns: 1fr;
            }
            .pagination {
                flex-wrap: wrap;
                gap: 5px;
            }
            .page-btn {
                padding: 8px 12px;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        <p class="intro">Aqui você encontra uma mini enciclopédia com informações detalhadas de cada Pokémon: tipos, habilidades, medidas e curiosidades.</p>
        <div class="pokemon-grid">
            <% pokemons.forEach(pokemon => { %>
                <div class="pokemon-card">
                    <div class="pokemon-card-header">
                        <img class="pokemon-image" src="<%= pokemon.image %>" alt="<%= pokemon.name %>">
                        <div class="pokemon-card-title">
                            <h2 class="pokemon-name"><%= pokemon.name %></h2>
                            <div class="pokemon-meta">
                                <span class="pokemon-number">#<%= pokemon.number %></span>
                                <span class="pokemon-category"><%= pokemon.category %></span>
                            </div>
                            <div class="pokemon-types">
                                <% pokemon.type.forEach(type => { %>
                                    <span class="pokemon-type"><%= type %></span>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    <p class="pokemon-description"><%= pokemon.description %></p>
                    <div class="pokemon-specs">
                        <div><strong>Altura:</strong> <%= pokemon.height %></div>
                        <div><strong>Peso:</strong> <%= pokemon.weight %></div>
                    </div>
                    <div class="pokemon-abilities">
                        <strong>Habilidades:</strong>
                        <ul>
                            <% pokemon.abilities.forEach(ability => { %>
                                <li><%= ability %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Controles de Paginação -->
        <div class="pagination">
            <% if (hasPrev) { %>
                <a href="?page=<%= prevPage %>" class="page-btn prev-btn">← Anterior</a>
            <% } %>
            
            <div class="page-numbers">
                <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="page-btn current-page"><%= i %></span>
                    <% } else { %>
                        <a href="?page=<%= i %>" class="page-btn"><%= i %></a>
                    <% } %>
                <% } %>
            </div>
            
            <% if (hasNext) { %>
                <a href="?page=<%= nextPage %>" class="page-btn next-btn">Próximo →</a>
            <% } %>
        </div>
    </div>
</body>
</html>